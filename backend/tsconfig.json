{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"skipLibCheck": true,
		"noEmit": true,
		"lib": ["ESNext"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx",
		"types": ["@cloudflare/workers-types"]
	},
	"include": ["src/**/*"]
}
